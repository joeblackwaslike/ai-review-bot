# GitHub App credentials (Claude / Anthropic)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# GitHub App credentials (Codex / OpenAI)
OPENAI_APP_ID=
OPENAI_APP_PRIVATE_KEY=
OPENAI_APP_WEBHOOK_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Review behavior
# REVIEW_ENABLED=false      # uncomment to disable auto-review (enabled by default)
# REVIEW_DELAY_SECONDS=450  # delay before auto-review fires on PR open (default: 450 = 7.5 min)
REVIEW_COMMAND=/claude-review
REVIEW_COMMENT_PREFIX=claude-review-bot
CUSTOM_REVIEW_PROMPT=
