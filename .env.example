# Claude bot — GitHub App credentials
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Codex bot — GitHub App credentials
OPENAI_APP_ID=
OPENAI_APP_PRIVATE_KEY=
OPENAI_APP_WEBHOOK_SECRET=

# API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Shared behavior (all optional — defaults shown)
# REVIEW_ENABLED=true          # set to false to disable auto-review on PR open/push
# REVIEW_DELAY_SECONDS=540          # delay before the INITIAL auto-review (default 9 min — lets slower external bots like CodeRabbit post first so we can dedupe)
# REVIEW_RESYNC_DELAY_SECONDS=300   # delay before a RE-review after a push/synchronize (default 5 min — external bots re-review incrementally, faster than their first pass)
# REVIEW_COMMAND=/ai-review    # slash command that triggers both bots
# CUSTOM_REVIEW_PROMPT=        # extra instructions appended to every agent's system prompt
# AGENT_CONCURRENCY=1          # max review agents run in parallel per PR (default 1 — sequential, to stay under provider ITPM rate limits)
# REVIEW_TIER2_ENABLED=true    # Tier 2 review skills. Defaults ON now that the QStash scheduler frees the full 800s function budget (the delay no longer burns it). Set to "false" to force off (e.g. if running without QStash and worried about ~8 agents hitting maxDuration).

# QStash delayed-review scheduler (optional, but recommended in production).
# Replaces the in-process review delay with a delayed QStash callback to
# /api/github/review-run, so the wait costs zero function time and the review
# runs with the full 800s budget. WITHOUT these the bot falls back to the legacy
# in-process delay (never drops a review, but the delay burns the function budget
# and risks the maxDuration kill on large Tier 2 reviews).
# PUBLIC_URL must be the STABLE production origin (no trailing slash): QStash
# signs the destination URL into the JWT, so the publish URL and the verify URL
# must be byte-identical — never derive it from per-request host headers.
# QSTASH_TOKEN=                      # Upstash QStash publish token
# QSTASH_CURRENT_SIGNING_KEY=        # current signing key (callback verification)
# QSTASH_NEXT_SIGNING_KEY=           # next signing key (rotation)
# PUBLIC_URL=https://ai-review-bot.vercel.app  # stable prod origin, no trailing slash

# Upstash Redis (optional, but recommended). Powers the duplicate-review
# idempotency guard — without it the bot falls back to a best-effort marker check
# that can't stop concurrent/redelivered invocations from posting (and paying for)
# the same review more than once. Also required for 👍/👎 feedback capture.
# KV_REST_API_URL=             # Upstash Redis REST URL
# KV_REST_API_TOKEN=           # Upstash Redis REST token

# Inline-comment feedback capture (all optional)
# FEEDBACK_ENABLED=false       # set true to record 👍/👎 reactions on inline comments (requires KV above)
# CRON_SECRET=                 # shared secret the /api/cron/poll-feedback endpoint requires
